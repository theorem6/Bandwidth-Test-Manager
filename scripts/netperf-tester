#!/bin/bash
# netperf-tester rev 2026-04-12 (writable HOME for Ookla ~/.config/ookla; NETPERF_OOKLA_HOME overrides)
#
# History: before 2026-04-07, speedtest stderr was often "2>/dev/null" — C++/Ookla failures were invisible.
# We now log to speedtest.stderr.log and set HOME=/var/lib/netperf-ookla so ~/.config/ookla is writable.
set -eu

### Root check ###
if [ "$(id -u)" -ne 0 ]; then
	echo -e "\nMUST BE RUN AS ROOT!\n"; exit 1
fi

### Variables ###
STORAGE_LOCATION="${1:-}"
CONFIG_FILE="${NETPERF_CONFIG:-/etc/netperf/config.json}"

### Process input options ###
process_arguments() {
	if [ -z "${STORAGE_LOCATION:-}" ]; then
		echo -e "\nIncorrect input.\n"; HELP ; exit 1;
	fi

	case "${STORAGE_LOCATION:-}" in
		-h|help|-help|--help|/?) HELP ; exit 0;;
		*) ;;
	esac
}

### Help subroutine ###
HELP() {
	echo -e "Script to run the netperf programs iPerf and Ookla Speedtest CLI."
	echo -e "Uses server list from: $CONFIG_FILE"
	echo -e "\nSyntax: netperf-tester [STORAGE_LOCATION|h]"
	echo -e "options:"
	echo -e "h\t\tShow this help."
	echo
}

### Start subroutine ###
START() {
	# Non-login shells (cron, systemd) often omit /usr/local/bin; Ookla CLI installs there.
	export PATH="/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"
	# Ookla writes $HOME/.config/ookla/speedtest-cli.json — /root may be unwritable (hardening, containers).
	export HOME="${NETPERF_OOKLA_HOME:-/var/lib/netperf-ookla}"
	mkdir -p "$HOME/.config/ookla"
	chmod 755 "$HOME" "$HOME/.config" "$HOME/.config/ookla" 2>/dev/null || true
	# Cron/systemd often omit these; some C++ CLIs misbehave with an empty TERM or TMPDIR.
	export TERM="${TERM:-xterm-256color}"
	export TMPDIR="${TMPDIR:-/tmp}"
	export USER="${USER:-$(id -un 2>/dev/null || echo root)}"
	export LOGNAME="${LOGNAME:-$USER}"

	if [ ! -d "$STORAGE_LOCATION" ]; then
		mkdir -p "$STORAGE_LOCATION"
	fi

	if [ ! -f "$CONFIG_FILE" ]; then
		echo -e "ERROR: Config not found: $CONFIG_FILE\n"; exit 1
	fi

	if ! command -v jq >/dev/null 2>&1; then
		echo -e "ERROR: jq is required to read config.\n"; exit 1
	fi

	# Prefer official Ookla binary (matches web/main.py and netperf-resolve-ookla-local).
	if [ -x /usr/local/bin/speedtest ]; then
		SPEEDTEST_BIN=/usr/local/bin/speedtest
	elif command -v speedtest >/dev/null 2>&1; then
		SPEEDTEST_BIN=$(command -v speedtest)
	else
		SPEEDTEST_BIN=""
		echo "netperf-tester: speedtest not found in PATH (cron often lacks /usr/local/bin). iperf will still run." >&2
	fi

	# Optional speed limit in Mbps (trickle KB/s = Mbps * 1000 / 8). Set NETPERF_SKIP_TRICKLE=1 to disable.
	LIMIT_MBPS=$(jq -r '.speedtest_limit_mbps // empty' "$CONFIG_FILE")
	LIMIT_KBPS=""
	if [ "${NETPERF_SKIP_TRICKLE:-}" = "1" ]; then
		:
	elif [ -n "$SPEEDTEST_BIN" ] && [ -n "$LIMIT_MBPS" ] && [ "$LIMIT_MBPS" != "null" ]; then
		LIMIT_KBPS=$(awk "BEGIN { printf \"%.0f\", ($LIMIT_MBPS * 1000) / 8 }")
	fi

	# Filenames only: labels like "ISP / nearest (auto)" must not contain / or spaces (breaks redirects).
	sanitize() { echo "$1" | tr -c '[:alnum:]._-' '_' | sed 's/__*/_/g; s/^_//; s/_$//' | tr '[:upper:]' '[:lower:]' || echo "unknown"; }

	# Ookla Speedtest: run each server from config. If ookla_servers is empty, run one Auto test
	# so scheduled runs still produce Speedtest data when only iperf is explicitly configured.
	# Errors (e.g. missing binary) go to speedtest.stderr.log — install links /usr/local/bin/speedtest.
	# Use a function so paths are never word-split wrong; LC_ALL=C avoids some libc string crashes in older CLIs.
	# License/GDPR: required for non-interactive runs. Direct exec avoids bash -c quoting bugs; PTY retries SIGABRT.
	# NETPERF_SKIP_TRICKLE=1 disables rate limit. NETPERF_OOKLA_OFF=1 skips all Ookla runs (iperf still runs).
	STERR="$STORAGE_LOCATION/speedtest.stderr.log"
	run_st() {
		local outfile="$1"
		shift
		export LC_ALL=C
		export LANGUAGE=C
		[ -n "$SPEEDTEST_BIN" ] || return 0
		local rc=0
		local bin="$SPEEDTEST_BIN"
		_ookla_pty() {
			local try="$1"
			shift
			local cmd
			cmd=$(printf '%q ' "$try" --accept-license --accept-gdpr "$@" -f json)
			SHELL=/bin/bash script -q -e -c "$cmd" /dev/null >>"$outfile" 2>>"$STERR"
			return $?
		}
		# Direct argv to Ookla (no bash -c); on abort (134/139) retry under pseudo-TTY if script(1) exists.
		_ookla_try() {
			local try="$1"
			local xrc
			shift
			if [ "${NETPERF_FORCE_PTY:-0}" = "1" ] && command -v script >/dev/null 2>&1; then
				_ookla_pty "$try" "$@"
				return $?
			fi
			if "$try" --accept-license --accept-gdpr "$@" -f json >>"$outfile" 2>>"$STERR"; then
				return 0
			fi
			xrc=$?
			if { [ "$xrc" -eq 134 ] || [ "$xrc" -eq 139 ]; } && command -v script >/dev/null 2>&1; then
				{
					echo "netperf-tester: speedtest rc=$xrc (abort); retrying under pseudo-TTY — if this persists, reinstall /usr/local/bin/speedtest from https://www.speedtest.net/apps/cli"
				} >>"$STERR"
				_ookla_pty "$try" "$@"
				return $?
			fi
			return "$xrc"
		}
		if [ -n "$LIMIT_KBPS" ] && command -v trickle >/dev/null 2>&1; then
			if trickle -d "$LIMIT_KBPS" -u "$LIMIT_KBPS" "$bin" --accept-license --accept-gdpr "$@" -f json >>"$outfile" 2>>"$STERR"; then
				rc=0
			else
				rc=$?
				{
					echo "netperf-tester: speedtest exited $rc with trickle; retrying without rate limit"
				} >>"$STERR"
				_ookla_try "$bin" "$@"
				rc=$?
			fi
		else
			_ookla_try "$bin" "$@"
			rc=$?
		fi
		if [ "$rc" -ne 0 ] && [ "$bin" != "/usr/local/bin/speedtest" ] && [ -x /usr/local/bin/speedtest ]; then
			{
				echo "netperf-tester: speedtest exited $rc with $bin; retrying with /usr/local/bin/speedtest"
			} >>"$STERR"
			_ookla_try /usr/local/bin/speedtest "$@" || true
		fi
		return 0
	}
	if [ "${NETPERF_OOKLA_OFF:-0}" = "1" ]; then
		echo "netperf-tester: NETPERF_OOKLA_OFF=1 — skipping all Ookla speedtest runs (iperf unchanged)" >>"$STERR"
	elif [ -n "$SPEEDTEST_BIN" ]; then
		OOKLA_N=$(jq '.ookla_servers // [] | length' "$CONFIG_FILE" 2>/dev/null || echo 0)
		if [ "${OOKLA_N:-0}" -eq 0 ]; then
			outfile="$STORAGE_LOCATION/0_speedtest-auto"
			run_st "$outfile"
		else
			idx=0
			while true; do
				id=$(jq -r --argjson i "$idx" '.ookla_servers[$i].id // empty' "$CONFIG_FILE")
				label=$(jq -r --argjson i "$idx" '.ookla_servers[$i].label // empty' "$CONFIG_FILE")
				[ -z "$id" ] && break
				label_safe=$(sanitize "$label")
				[ -z "$label_safe" ] && label_safe="server${idx}"
				outfile="$STORAGE_LOCATION/${idx}_speedtest-${label_safe}"
				if [ "$id" = "auto" ]; then
					run_st "$outfile"
				elif [ "$id" = "local" ]; then
					RESOLVED=""
					if command -v netperf-resolve-ookla-local >/dev/null 2>&1; then
						RESOLVED=$(netperf-resolve-ookla-local "$CONFIG_FILE" 2>/dev/null || true)
					fi
					if [ -n "$RESOLVED" ]; then
						run_st "$outfile" -s "$RESOLVED"
					else
						run_st "$outfile"
					fi
				else
					run_st "$outfile" -s "$id"
				fi
				sleep 10
				idx=$((idx + 1))
			done
		fi
	fi

	# iperf3: run each server × each test from config (duration from config, default 10s)
	IPERF_DURATION=$(jq -r '.iperf_duration_seconds // 10' "$CONFIG_FILE")
	[ -z "$IPERF_DURATION" ] || [ "$IPERF_DURATION" = "null" ] && IPERF_DURATION=10
	server_idx=0
	while true; do
		host=$(jq -r --argjson i "$server_idx" '.iperf_servers[$i].host // empty' "$CONFIG_FILE")
		slabel=$(jq -r --argjson i "$server_idx" '.iperf_servers[$i].label // empty' "$CONFIG_FILE")
		[ -z "$host" ] && break
		slabel_safe=$(sanitize "$slabel")
		[ -z "$slabel_safe" ] && slabel_safe="server$server_idx"
		test_idx=0
		while true; do
			tname=$(jq -r --argjson i "$test_idx" '.iperf_tests[$i].name // empty' "$CONFIG_FILE")
			targs=$(jq -r --argjson i "$test_idx" '.iperf_tests[$i].args // empty' "$CONFIG_FILE")
			[ -z "$tname" ] && break
			tname_safe=$(sanitize "$tname")
			[ -z "$tname_safe" ] && tname_safe="test$test_idx"
			outfile="$STORAGE_LOCATION/iperf-${slabel_safe}-${tname_safe}.txt"
			iperf3 --timestamp -c "$host" $targs -t "$IPERF_DURATION" >> "$outfile" 2>/dev/null || true
			sleep 10
			test_idx=$((test_idx + 1))
		done
		server_idx=$((server_idx + 1))
	done

	exit 0
}

process_arguments "$@"
START
