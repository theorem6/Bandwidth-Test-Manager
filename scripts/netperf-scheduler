#!/bin/bash
set -eu

### Root check ###
if [ "$(id -u)" -ne 0 ]; then
	echo -e "\nMUST BE RUN AS ROOT!\n"; exit 1
fi

### Variables ###
CONFIG_FILE="${NETPERF_CONFIG:-/etc/netperf/config.json}"
# Schedule from config (default: 5 past every hour). Use wrapper so each run uses current date.
if [ -f "$CONFIG_FILE" ] && command -v jq >/dev/null 2>&1; then
	CRON_SCHEDULE=$(jq -r '.cron_schedule // "5 * * * *"' "$CONFIG_FILE")
else
	CRON_SCHEDULE="5 * * * *"
fi
CRON_JOB="$CRON_SCHEDULE /bin/netperf-cron-run"

### Process input options ###
process_arguments() {
	if [ -z "${1:-}" ]; then
		echo -e "\nIncorrect input.\n"; HELP ; exit 1
	fi

	case "$1" in
		-h|help|-help|--help|/?) HELP; exit 0;;
		start|-start|--start) START;;
		stop|-stop|--stop) STOP;;
		*) echo -e "\nIncorrect input.\n"; HELP; exit 1;;
	esac
}

### Help subroutine ###
HELP() {
	echo -e "Script to enable/disable automated and logged speed testing."
	echo -e "\nSyntax: netperf-scheduler [start|stop|h]"
	echo -e "options:"
	echo -e "\tstart\tStart speed test logging"
	echo -e "\tstop\tStop the speed test logging"
	echo -e "\th\t\tShow this help."
	echo
}

### Start subroutine ###
START() {
	mkdir -p /var/log/netperf
	# Remove any existing netperf cron line(s) so we never have duplicates (one schedule for both Ookla and iperf3)
	(crontab -l 2>/dev/null | sed '/netperf/d' || true) | crontab -
	# Add exactly one job: runs netperf-cron-run (which runs speedtest then iperf3 once per tick)
	(crontab -l 2>/dev/null; echo "$CRON_JOB") | crontab -
	systemctl restart cron.service 2>/dev/null || true
	systemctl restart crond.service 2>/dev/null || true
	echo -e "\nnetperf scheduled successfully (Ookla + iperf3 on same schedule).\n"
}

### Stop subroutine ###
STOP() {
	(crontab -l 2>/dev/null | sed '/netperf/d' || true) | crontab -
	systemctl restart cron.service 2>/dev/null || true
	systemctl restart crond.service 2>/dev/null || true
	echo -e "\nnetperf schedule removed.\n"
}

process_arguments "$@"
